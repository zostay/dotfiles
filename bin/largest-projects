#!/usr/bin/env bash
set -u
shopt -s nullglob

dirs=()

# Top-level projects, two levels deep. Skip ~/projects/go's bin/pkg/src
# subtrees — bin and pkg are Go build caches (not projects), and src is
# the parent of the real Go projects, expanded separately below.
for d in "$HOME"/projects/*/*; do
    case $d in
        "$HOME"/projects/go/bin|"$HOME"/projects/go/pkg|"$HOME"/projects/go/src)
            continue ;;
    esac
    dirs+=("$d")
done

# Go projects follow workon's $GOPATH/src/<host>/<owner>/<repo> convention.
for d in "$HOME"/projects/go/src/*/*/*; do
    [[ -d $d ]] || continue
    dirs+=("$d")
done

exec "$(dirname "$0")/largest-dirs" "$@" "${dirs[@]}"
