#!/bin/zsh

# recon-loop: keep `recon` running in a pane. If it exits (clean or crash),
# pause briefly and relaunch. If recon isn't installed, print a hint and
# back off so we don't spin.

emulate -L zsh

while true; do
    if ! command -v recon >/dev/null 2>&1; then
        clear
        print -P "%F{244}recon not on PATH — install from https://github.com/gavraz/recon%f"
        print -P "%F{244}retrying in 30s; ctrl-c to give up%f"
        sleep 30
        continue
    fi

    recon

    # Brief pause so a tight crash loop doesn't peg CPU.
    sleep 0.5
done
