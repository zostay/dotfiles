#!/bin/zsh

# Parse command line options
WORK_NAME="prime"
EDITOR_MODE=0

while getopts "w:e" opt; do
    case $opt in
        w)
            WORK_NAME="$OPTARG"
            ;;
        e)
            EDITOR_MODE=1
            ;;
        \?)
            echo "Invalid option: -$OPTARG" >&2
            exit 1
            ;;
    esac
done

shift $((OPTIND-1))

NAME=$1
DIR=$2

function initialize_session {
    SESSION_NAME="$1"
    SESSION_DIR="$2"
    CLAUDE_WORK="$3"
    SHORT_DIR=$( basename $( dirname "$SESSION_DIR" ) )

    add-claude "$SESSION_NAME" "$SESSION_DIR" "$CLAUDE_WORK"

    if (( $EDITOR_MODE )); then
        add-editor "$SESSION_NAME" "$SESSION_DIR"
    fi

    case $SHORT_DIR in
        raku)
            add-repl "$SESSION_NAME" "$SESSION_DIR"
            ;;
    esac

    tmux select-window -t \="$SESSION_NAME:0"
}

SHORTEN=0
if [[ "$NAME" == "" ]]; then
    NAME=stuff
else
    SHORTEN=1
fi

if [[ "$DIR" == "" ]]; then
    if [[ "$NAME" != "stuff" ]]; then
        DIR="$NAME"
    else
        DIR="$HOME"
    fi
fi

if (( $SHORTEN )); then
    # workon 0/dotfiles => dotfiles
    NAME=$( basename $NAME )
fi

if [[ "${DIR:0:1}" != "/" ]]; then
    if [[ -d "$HOME/projects/$DIR" ]]; then
        DIR="$HOME/projects/$DIR"
    elif [[ -d "$GOPATH/src/github.com/$DIR" ]]; then
        DIR="$GOPATH/src/github.com/$DIR"
    elif [[ -d "$PWD/$DIR" ]]; then
        DIR="$PWD/$DIR"
    else
        DIR="$HOME"
    fi
fi

NAME="${NAME//\./-}"

# Resolve worktree path (no-op for WORK_NAME=prime).
if ! WORK_DIR=$( work-worktree "$DIR" "$WORK_NAME" ); then
    exit 1
fi

# Session name encodes the work; prime stays bare for the most-common case.
if [[ "$WORK_NAME" == "prime" ]]; then
    SESSION_NAME="$NAME"
else
    SESSION_NAME="${NAME}-${WORK_NAME}"
fi

if [[ -n "$TMUX" ]] && tmux display-message -p '#S' | grep "^$SESSION_NAME$" >/dev/null; then
    echo "This is the [$SESSION_NAME] session!";
else
    if ! tmux has-session -t \="$SESSION_NAME" &>/dev/null; then
        # Pin the new (detached) session's dimensions to the current client
        # / terminal so percentage-based splits inside add-claude resolve
        # against the right canvas. tmux's default-size is 80x24, which
        # would otherwise distort the layout once a real terminal attaches.
        if [[ -n "$TMUX" ]]; then
            cols=$(  tmux display-message -p '#{client_width}'  )
            lines=$( tmux display-message -p '#{client_height}' )
        else
            # `stty size` reads from the controlling tty directly — more
            # reliable than `tput`, which falls back to 80x24 whenever the
            # terminfo lookup is ambiguous.
            sz=( ${(z)"$(stty size 2>/dev/null)"} )
            lines=${sz[1]:-60}
            cols=${sz[2]:-200}
        fi

        # Resolve the per-session env cascade (.workon.env / .workon.local.env
        # from $HOME down to the session dir). Sets become `-e KEY=VAL` on the
        # session, which tmux seeds into the session environment so every pane
        # (shell, claude, recon, editor, and ad-hoc splits) inherits them.
        env_set_args=() ; env_unset_keys=()
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            if [[ "$line" == -* ]]; then
                env_unset_keys+=( "${line#-}" )
            else
                env_set_args+=( -e "$line" )
            fi
        done < <( workon-env "$WORK_DIR" )

        # Pane 0 is spawned by new-session itself, so the set-environment -r
        # below can't strip inherited vars from it. Tell its supervisor to
        # clear them in-process before it launches the shell.
        sup0="work-supervisor --default=zsh"
        for k in "${env_unset_keys[@]}"; do
            sup0+=" --unset ${(q)k}"
        done

        tmux new-session -d -x "$cols" -y "$lines" \
            "${env_set_args[@]}" \
            -c "$WORK_DIR" -s "$SESSION_NAME" "$sup0"

        # Strip unset vars from the session environment so panes created below
        # (claude, recon, editor) don't inherit them.
        for k in "${env_unset_keys[@]}"; do
            tmux set-environment -t \="$SESSION_NAME" -r "$k"
        done

        # Tell add-claude (and from there work-supervisor) to launch
        # `claude -w WORK_NAME` so the WorktreeCreate hook fires and claude
        # treats the existing worktree as managed. Prime sessions stay bare.
        if [[ "$WORK_NAME" == "prime" ]]; then
            CLAUDE_WORK=""
        else
            CLAUDE_WORK="$WORK_NAME"
        fi
        initialize_session "$SESSION_NAME" "$WORK_DIR" "$CLAUDE_WORK"
    fi

    if [[ -n "$TMUX" ]]; then
        tmux switch-client -t \="$SESSION_NAME"
    else
        tmux attach-session -t \="$SESSION_NAME"
    fi
fi
