#!/bin/zsh

# work-supervisor: keep a pane alive after the wrapped command exits.
#
# Runs the chosen command; when it exits, presents an in-pane menu to
# relaunch an agent (claude / codex / copilot), a shell, or close the pane.
#
# The menu is data-driven. CMD_* below is the registry of known launchers;
# the MENU array picks which ones to show and in what order. Override the
# order/set per-machine or per-project via the WORK_SUPERVISOR_MENU env var
# (space-separated tokens, e.g. "claude copilot shell"), which the workon-env
# cascade can set. Items whose backing binary isn't installed render dimmed
# and are not selectable, so the menu reflects what's actually available on
# this machine.

emulate -L zsh
setopt no_unset

DEFAULT=claude
WORKTREE=""
typeset -a UNSETS
while [[ $# -gt 0 ]]; do
    case $1 in
        --default=*)  DEFAULT="${1#--default=}"; shift ;;
        --default)    DEFAULT="$2"; shift 2 ;;
        --worktree=*) WORKTREE="${1#--worktree=}"; shift ;;
        --worktree)   WORKTREE="$2"; shift 2 ;;
        --unset=*)    UNSETS+=( "${1#--unset=}" ); shift ;;
        --unset)      UNSETS+=( "$2" ); shift 2 ;;
        --) shift; break ;;
        *)  echo "work-supervisor: unknown arg: $1" >&2; exit 2 ;;
    esac
done

# `zsh` is an alias for the shell launcher (workon passes --default=zsh).
[[ "$DEFAULT" == zsh ]] && DEFAULT=shell

# Registry of known launchers. For each token: the menu key, the display
# label, and the binary whose presence on $PATH means "installed" (empty =
# always available, e.g. the shell). To add a launcher, add a row here and a
# case in run_choice; list its token in MENU (or WORK_SUPERVISOR_MENU) to show it.
typeset -A CMD_KEY CMD_LABEL CMD_BIN
CMD_KEY=(   claude c        codex o       copilot p         shell s )
CMD_LABEL=( claude Claude   codex Codex   copilot Copilot   shell shell )
CMD_BIN=(   claude claude   codex codex   copilot copilot   shell '' )

# Which launchers to offer, in order. WORK_SUPERVISOR_MENU overrides the default.
typeset -a MENU
if [[ -n "${WORK_SUPERVISOR_MENU:-}" ]]; then
    MENU=( ${(s: :)WORK_SUPERVISOR_MENU} )
else
    MENU=( claude codex copilot shell )
fi

is_installed() {
    local bin="${CMD_BIN[$1]:-}"
    [[ -z "$bin" ]] && return 0
    command -v "$bin" >/dev/null 2>&1
}

# Pane 0 inherits the session environment that new-session created before
# `tmux set-environment -r` could strip these, so clear them here. claude/codex/
# shell launched below are children of this process and inherit the cleansed env.
for k in "${UNSETS[@]}"; do
    unset "$k"
done

next="$DEFAULT"

# --worktree NAME makes every claude relaunch go through `claude -w NAME`,
# which triggers the WorktreeCreate hook (bin/work-worktree-hook) so claude
# treats this session as worktree-managed instead of chdir'ing back to the
# main checkout. Bare `claude` would re-trip that bug on the next relaunch.
run_choice() {
    case $1 in
        claude)
            if [[ -n "$WORKTREE" ]]; then
                claude --chrome -w "$WORKTREE"
            else
                claude --chrome
            fi
            ;;
        codex)     codex ;;
        copilot)   copilot ;;
        shell|zsh) ${SHELL:-zsh} -l ;;
        *) return 1 ;;
    esac
}

label_for() {
    echo "${CMD_LABEL[$1]:-$1}"
}

typeset -A keymap
while true; do
    run_choice "$next"

    # Menu loop: prompt for the next action. An unknown key redraws the menu
    # rather than relaunching anything — only a valid choice `break`s out to
    # run a command. (A bare `continue` here would jump to the top of the
    # OUTER loop and re-run run_choice "$next", silently relaunching.)
    while true; do
        print
        print -P "%F{244}── $(label_for "$next") exited ──%f"

        # Render the menu from MENU, building key->token for the *selectable*
        # (installed) items only. Uninstalled launchers show dimmed and their
        # key is left out of keymap, so pressing it just redraws.
        keymap=()
        for tok in "${MENU[@]}"; do
            mkey="${CMD_KEY[$tok]:-}"
            [[ -z "$mkey" ]] && continue   # unknown token in config -> skip
            mlabel="${(r:9:)${CMD_LABEL[$tok]:-$tok}}"
            mtag=""
            [[ "$tok" == "$DEFAULT" ]] && mtag="(default)"
            if is_installed "$tok"; then
                keymap[$mkey]="$tok"
                print -P "  [$mkey] $mlabel $mtag"
            else
                print -P "%F{240}  [$mkey] $mlabel (not installed)%f"
            fi
        done
        print "  [x] close workon session"
        print -n "> "

        # Drain any pending/typeahead or stray escape-sequence bytes so they
        # can't be consumed as the menu choice. (-t 0 = non-blocking.) no_unset
        # is active, so drain into a throwaway and guard the empty-input case.
        while read -t 0 -k 1 _ 2>/dev/null; do :; done

        # Single-key read; Enter accepts default.
        if ! read -k 1 choice; then
            # stdin closed (pane killed underneath us) — give up cleanly.
            exit 0
        fi
        print

        case $choice in
            x|X)
                # End the whole work session — shell, claude, and sessions panes
                # all go together. Target the pane explicitly so we don't depend
                # on which session tmux considers "current".
                if [[ -n "$TMUX_PANE" ]]; then
                    session=$(tmux display-message -p -t "$TMUX_PANE" '#S')
                    exec tmux kill-session -t "=$session"
                fi
                exit 0
                ;;
            $'\n'|"")   next="$DEFAULT"; break ;;
            *)
                # Map the pressed key (case-insensitively) to a selectable token.
                sel="${keymap[${(L)choice}]:-}"
                if [[ -n "$sel" ]]; then
                    next="$sel"; break
                fi
                continue   # unknown/disabled key -> redraw menu, do NOT relaunch
                ;;
        esac
    done
done
