#!/bin/zsh

# work-supervisor: keep a pane alive after the wrapped command exits.
#
# Runs the chosen command; when it exits, presents an in-pane menu to
# relaunch claude / codex / a shell, or close the pane.

emulate -L zsh
setopt no_unset

DEFAULT=claude
WORKTREE=""
typeset -a UNSETS
while [[ $# -gt 0 ]]; do
    case $1 in
        --default=*)  DEFAULT="${1#--default=}"; shift ;;
        --default)    DEFAULT="$2"; shift 2 ;;
        --worktree=*) WORKTREE="${1#--worktree=}"; shift ;;
        --worktree)   WORKTREE="$2"; shift 2 ;;
        --unset=*)    UNSETS+=( "${1#--unset=}" ); shift ;;
        --unset)      UNSETS+=( "$2" ); shift 2 ;;
        --) shift; break ;;
        *)  echo "work-supervisor: unknown arg: $1" >&2; exit 2 ;;
    esac
done

# Pane 0 inherits the session environment that new-session created before
# `tmux set-environment -r` could strip these, so clear them here. claude/codex/
# shell launched below are children of this process and inherit the cleansed env.
for k in "${UNSETS[@]}"; do
    unset "$k"
done

next="$DEFAULT"

# --worktree NAME makes every claude relaunch go through `claude -w NAME`,
# which triggers the WorktreeCreate hook (bin/work-worktree-hook) so claude
# treats this session as worktree-managed instead of chdir'ing back to the
# main checkout. Bare `claude` would re-trip that bug on the next relaunch.
run_choice() {
    case $1 in
        claude)
            if [[ -n "$WORKTREE" ]]; then
                claude -w "$WORKTREE"
            else
                claude
            fi
            ;;
        codex)  codex ;;
        shell|zsh) ${SHELL:-zsh} -l ;;
        *) return 1 ;;
    esac
}

label_for() {
    case $1 in
        claude) echo "Claude" ;;
        codex)  echo "Codex" ;;
        shell|zsh) echo "shell" ;;
        *) echo "$1" ;;
    esac
}

while true; do
    run_choice "$next"

    # Menu loop: prompt for the next action. An unknown key redraws the menu
    # rather than relaunching anything — only a valid choice `break`s out to
    # run a command. (A bare `continue` here would jump to the top of the
    # OUTER loop and re-run run_choice "$next", silently relaunching.)
    while true; do
        print
        print -P "%F{244}── $(label_for "$next") exited ──%f"
        print "  [c] claude     (default)"
        print "  [o] codex"
        print "  [s] shell"
        print "  [x] close workon session"
        print -n "> "

        # Drain any pending/typeahead or stray escape-sequence bytes so they
        # can't be consumed as the menu choice. (-t 0 = non-blocking.) no_unset
        # is active, so drain into a throwaway and guard the empty-input case.
        while read -t 0 -k 1 _ 2>/dev/null; do :; done

        # Single-key read; Enter accepts default.
        if ! read -k 1 choice; then
            # stdin closed (pane killed underneath us) — give up cleanly.
            exit 0
        fi
        print

        case $choice in
            c|C)        next=claude; break ;;
            o|O)        next=codex;  break ;;
            s|S)        next=shell;  break ;;
            x|X)
                # End the whole work session — shell, claude, and recon panes
                # all go together. Target the pane explicitly so we don't depend
                # on which session tmux considers "current".
                if [[ -n "$TMUX_PANE" ]]; then
                    session=$(tmux display-message -p -t "$TMUX_PANE" '#S')
                    exec tmux kill-session -t "=$session"
                fi
                exit 0
                ;;
            $'\n'|"")   next=claude; break ;;
            *)          continue ;;   # unknown key -> redraw menu, do NOT relaunch
        esac
    done
done
