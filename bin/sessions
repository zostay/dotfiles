# ── Helpers ───────────────────────────────────────────────────────────────────

def trunc(s: str, width: int) -> str:
    s = str(s)
    if len(s) <= width:
        return s.ljust(width)
    return s[:width - 1] + "~"


BRANCH_GLYPH = ""  # Nerd Font powerline branch symbol
STAR_GLYPH   = "★"  # filled five-pointed star marking the current tmux session


def branch_visible(branch) -> bool:
    return bool(branch) and branch.lower() not in ("main", "master")


def parent_basename(path: str) -> str:
    """/Users/sterling/projects/bambee/panfactum -> bambee/panfactum."""
    if not path:
        return ""
    parent = os.path.basename(os.path.dirname(path))
    base   = os.path.basename(path)
    return f"{parent}/{base}" if parent else base


def pretty_model(name: str) -> str:
    """claude-sonnet-4-6 -> Sonnet 4.6, gpt-5.5 -> GPT 5.5."""
    if not name:
        return ""
    n = name.strip()
    if n.startswith("claude-"):
        parts = n.split("-")
        # claude-{family}-{maj}-{min} → "Family maj.min"
        if len(parts) >= 4:
            family = parts[1].capitalize()
            return f"{family} {parts[2]}.{parts[3]}"
        return n
    if n.startswith("gpt-"):
        return "GPT " + n[4:]
    return n


def fmt_age(ts) -> str:
    """ISO-8601 string or millisecond int → relative time string."""
    if ts is None:
        return "-"
    now = datetime.now(timezone.utc)
    if isinstance(ts, str):
        try:
            dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        except ValueError:
            return "?"
    else:
        dt = datetime.fromtimestamp(ts / 1000, tz=timezone.utc)
    secs = max(0, int((now - dt).total_seconds()))
    if secs < 60:
        return f"{secs}s ago"
    if secs < 3600:
        return f"{secs // 60}m ago"
    if secs < 86400:
        return f"{secs // 3600}h ago"
    return f"{secs // 86400}d ago"


def fmt_tokens(n: int) -> str:
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M tok"
    if n >= 1_000:
        return f"{n // 1_000}k tok"
    return f"{n} tok"


def ts_seconds(s: dict) -> float:
    """Return sort key (Unix seconds) for a session record."""
    ts = s.get("ts")
    if ts is None:
        return 0.0
    if isinstance(ts, str):
        try:
            return datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
        except ValueError:
            return 0.0
    return ts / 1000.0


# ── Shared tmux pane + process scan ───────────────────────────────────────────

def scan_panes() -> tuple:
    """One snapshot shared by both agents.

    Returns (pane_info, ppid_map, procs):
      pane_info: {pane_pid: (session_name, pane_path, pane_id)}
      ppid_map:  {pid: ppid}
      procs:     [(pid, ppid, command), ...]

    Agents run under wrappers (work-supervisor/zsh for Claude, a node shim for
    Codex), so the foreground pane process is not the agent itself. Callers find
    the agent process in `procs`, then walk `ppid_map` up to a pane_pid to learn
    which tmux session/path/pane owns it.
    """
    pane_info = {}
    try:
        r = subprocess.run(
            ["tmux", "list-panes", "-a", "-F",
             "#{pane_pid}|||#{session_name}|||#{pane_current_path}|||#{pane_id}"],
            capture_output=True, text=True, timeout=5,
        )
        for line in r.stdout.splitlines():
            parts = line.split("|||", 3)
            if len(parts) == 4:
                try:
                    pane_info[int(parts[0])] = (parts[1], parts[2], parts[3])
                except ValueError:
                    pass
    except Exception:
        pass

    ppid_map = {}
    procs    = []
    try:
        ps = subprocess.run(
            ["ps", "-axo", "pid=,ppid=,command="],
            capture_output=True, text=True, timeout=5,
        )
        for line in ps.stdout.splitlines():
            parts = line.strip().split(None, 2)
            if len(parts) < 3:
                continue
            try:
                pid, ppid = int(parts[0]), int(parts[1])
            except ValueError:
                continue
            ppid_map[pid] = ppid
            procs.append((pid, ppid, parts[2]))
    except Exception:
        pass

    return pane_info, ppid_map, procs


def owning_pane(pid: int, ppid_map: dict, pane_info: dict):
    """Walk ppid from `pid` up to the first known pane_pid → (session, path)."""
    cur = pid
    for _ in range(20):
        if cur in pane_info:
            return pane_info[cur]
        nxt = ppid_map.get(cur)
        if not nxt or nxt <= 1:
            return None
        cur = nxt
    return None


# ── Claude sessions (via per-pid registry + JSONL transcripts) ────────────────
#
# Each running `claude` process is one session. Claude records authoritative
# per-process state in <config_dir>/sessions/<pid>.json — sessionId (→ the exact
# transcript), cwd, and a live status (busy/idle/shell). The config dir defaults
# to ~/.claude but per-client setups (e.g. bambee) point CLAUDE_CONFIG_DIR
# elsewhere, so both the registry and transcripts live under that dir, not
# ~/.claude. We therefore key on the process, learn its config dir from the
# environment, then read its registry and transcript.

# Claude's own per-process status → our status vocabulary.
REG_STATUS = {"busy": "Running", "idle": "Idle", "shell": "Idle"}


def is_claude_cmd(cmd: str) -> bool:
    # The Claude Code CLI is bare "claude" (optionally with args). Exclude the
    # Claude.app desktop helper, which carries a full /Applications/... path.
    return cmd == "claude" or cmd.startswith("claude ")


def claude_config_dirs(pids: list) -> dict:
    """{pid: CLAUDE_CONFIG_DIR} for the given pids, from their environment.

    A session under a non-default config dir writes its registry and transcripts
    there, so we must learn each process's config dir to find its state."""
    res = {}
    if not pids:
        return res
    cmd = ["ps", "eww", "-o", "pid=,command="]
    for p in pids:
        cmd += ["-p", str(p)]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
    except Exception:
        return res
    for line in r.stdout.splitlines():
        parts = line.split(None, 1)
        if len(parts) != 2:
            continue
        try:
            pid = int(parts[0])
        except ValueError:
            continue
        cfg = CLAUDE_DEFAULT_CFG
        for tok in parts[1].split():
            if tok.startswith("CLAUDE_CONFIG_DIR="):
                cfg = tok.split("=", 1)[1]
                break
        res[pid] = cfg
    return res


def read_session_registry(cfg: str, pid: int):
    """Claude's <config_dir>/sessions/<pid>.json → dict, or None."""
    try:
        with open(os.path.join(cfg, "sessions", f"{pid}.json")) as fh:
            return json.load(fh)
    except (OSError, ValueError):
        return None


def mangle_cwd(cwd: str) -> str:
    """cwd → Claude's project-dir name (slashes and dots become dashes)."""
    return (cwd or "").replace("/", "-").replace(".", "-")


def transcript_for(cfg: str, cwd: str, session_id: str):
    """Exact transcript path for a session id, or None."""
    if not session_id:
        return None
    p = os.path.join(cfg, "projects", mangle_cwd(cwd), f"{session_id}.jsonl")
    return p if os.path.exists(p) else None


def newest_transcript(cfg: str, cwd: str):
    """Fallback when the session id is unknown: newest transcript in the project
    dir whose recorded cwd matches (mangling is lossy, so verify)."""
    proj  = os.path.join(cfg, "projects", mangle_cwd(cwd))
    files = sorted(glob.glob(os.path.join(proj, "*.jsonl")),
                   key=os.path.getmtime, reverse=True)
    for f in files:
        if jsonl_cwd(f) == cwd:
            return f
    return files[0] if files else None


def jsonl_cwd(path: str):
    """First `cwd` value recorded in a transcript (cheap: scans from the top)."""
    try:
        with open(path, "r") as fh:
            for line in fh:
                if '"cwd"' not in line:
                    continue
                try:
                    v = json.loads(line).get("cwd")
                except ValueError:
                    continue
                if v:
                    return v
    except OSError:
        pass
    return None


def parse_claude_jsonl(path: str) -> dict:
    """Pull model, context tokens, last timestamp, and last turn-type from a
    transcript. Skips sidechain (sub-agent) entries so a background agent's model
    and tokens don't masquerade as the main thread."""
    model      = ""
    usage      = None
    last_ts    = None
    last_turn  = ""           # "user" or "assistant" — last conversational entry

    # Read only the tail: the last assistant entry (with model+usage) is near the
    # end, and transcripts reach multiple MB. 512 KiB covers many turns; if the
    # markers aren't in it we accept partial info rather than read the whole file.
    try:
        size = os.path.getsize(path)
        with open(path, "rb") as fh:
            if size > 512 * 1024:
                fh.seek(-512 * 1024, os.SEEK_END)
                fh.readline()                      # drop the partial first line
            lines = fh.read().decode("utf-8", "replace").splitlines()
    except OSError:
        return {"model": model, "usage": usage, "ts": last_ts, "last_turn": last_turn}

    for line in reversed(lines):
        try:
            d = json.loads(line)
        except ValueError:
            continue
        if d.get("isSidechain"):
            continue
        typ = d.get("type")
        if last_ts is None and d.get("timestamp"):
            last_ts = d["timestamp"]
        if not last_turn and typ in ("user", "assistant"):
            last_turn = typ
        if not model and typ == "assistant":
            msg = d.get("message") or {}
            m   = msg.get("model")
            if m and m != "<synthetic>":
                model = m
                usage = msg.get("usage")
        if model and last_ts and last_turn:
            break
    return {"model": model, "usage": usage, "ts": last_ts, "last_turn": last_turn}


_model_windows = {"mtime": None, "map": {}}


def _load_model_windows() -> dict:
    """Model id -> context window (tokens) from MODELS_TABLE. Re-read whenever the
    file's mtime changes so a maintenance refresh is picked up without restarting
    the monitor. A missing or unparseable file yields an empty map (every model
    then reads as unknown), so the monitor never depends on the table existing."""
    try:
        mtime = os.stat(MODELS_TABLE).st_mtime
    except OSError:
        _model_windows["mtime"], _model_windows["map"] = None, {}
        return _model_windows["map"]
    if mtime != _model_windows["mtime"]:
        try:
            with open(MODELS_TABLE) as fh:
                data = json.load(fh)
            _model_windows["map"] = {
                mid: spec["context"]
                for mid, spec in (data.get("models") or {}).items()
                if isinstance(spec, dict) and spec.get("context")
            }
            _model_windows["mtime"] = mtime
        except (OSError, ValueError):
            pass   # keep the last good map rather than blanking on a transient error
    return _model_windows["map"]


def ctx_window(model: str):
    """Context window (tokens) for a model id, or None when it isn't in the table.
    Transcripts record pinned/suffixed ids (a [1m] fast-context tier, a -fast
    suffix, or a -YYYYMMDD snapshot), so try the id verbatim, then progressively
    strip those suffixes back to the bare alias the table is keyed on."""
    windows = _load_model_windows()
    m = model or ""
    if m in windows:
        return windows[m]
    m = re.sub(r"\[.*?\]$", "", m)    # drop a [1m]-style tier suffix
    m = re.sub(r"-fast$", "", m)      # drop the fast-tier suffix
    m = re.sub(r"-\d{8}$", "", m)     # drop a -YYYYMMDD pinned snapshot
    return windows.get(m)


# A live Claude turn renders a spinner line carrying an elapsed timer and a
# streaming token count — "✻ Gesticulating… (3m 1s · ↓ 11.5k tokens)" — or, on
# some turns, an "esc to interrupt"/"esc to cancel" hint. The verb animates and
# a *completed* turn leaves a past-tense summary ("✻ Brewed for 36s") with no
# ellipsis, so we key on the live payload — the in-progress ellipsis followed by
# a token count, or the interrupt hint — never the spinner glyph itself.
_SPINNER_RE = re.compile(r"esc to interrupt|esc to cancel|…[^\n]*\btokens?\b", re.I)

# A live attention prompt (permission / plan / trust) renders a numbered select
# with the cursor on an option: "❯ 1. Yes". The bare "❯" composer cursor shown
# while idle carries no digit, so requiring "❯ <n>." avoids matching it. The
# insert-mode footer ("-- INSERT --") only renders while the composer is active,
# so its absence confirms a real prompt has replaced the composer.
_SELECT_RE = re.compile(r"❯\s*\d+\.")


def _pane_tail(pane_target: str, lines: int = 12) -> str:
    """Lowercased text of the last `lines` non-empty rows of a pane, or "".

    The state signals (spinner, prompt, insert footer) all render in this bottom
    region; restricting to it keeps older scrollback prose from being misread as
    a live prompt."""
    try:
        cap = subprocess.run(
            ["tmux", "capture-pane", "-t", pane_target, "-p"],
            capture_output=True, text=True, timeout=2,
        ).stdout
    except Exception:
        return ""
    rows = [ln for ln in cap.splitlines() if ln.strip()]
    return "\n".join(rows[-lines:]).lower()


def claude_status(reg_status: str, pane_target: str, last_turn: str,
                  has_transcript: bool) -> tuple:
    """(status, waiting) for a Claude session.

    The live pane is ground truth for what Claude is doing *right now*, so it is
    consulted first: a streaming spinner means Running, a numbered attention
    prompt means Input, anything else Idle. Claude's self-reported registry
    status is only a fallback — older versions (≤2.1.169, no `statusUpdatedAt`)
    write "busy" and never flip it back to "idle", which otherwise pins a
    finished session to Running forever. The registry's explicit "waiting" is
    trusted up front: that state is unambiguous and its prompt may scroll
    off-pane.
    """
    if (reg_status or "") == "waiting":
        return "Input", True
    tail = _pane_tail(pane_target) if pane_target else ""
    if tail:
        if _SPINNER_RE.search(tail):
            return "Running", False
        if _SELECT_RE.search(tail) and "-- insert --" not in tail:
            return "Input", True
        return "Idle", False
    # No pane to read — fall back to the registry, then the transcript.
    if not has_transcript:
        return "New", False
    base = REG_STATUS.get(reg_status or "", "")
    if base:
        return base, False
    return ("Running", False) if last_turn == "user" else ("Idle", False)


def fetch_claude(pane_info: dict, ppid_map: dict, procs: list) -> list:
    claude_pids = [pid for pid, _ppid, cmd in procs if is_claude_cmd(cmd)]
    if not claude_pids:
        return []
    cfgs = claude_config_dirs(claude_pids)

    out  = []
    seen = set()
    for pid in claude_pids:
        owner = owning_pane(pid, ppid_map, pane_info)
        if not owner:
            continue
        tmux_session, pane_cwd, pane_target = owner

        cfg = cfgs.get(pid, CLAUDE_DEFAULT_CFG)
        reg = read_session_registry(cfg, pid) or {}
        sid = reg.get("sessionId")
        cwd = reg.get("cwd") or pane_cwd

        # One row per session id; a resumed session can briefly have two pids.
        if sid:
            if sid in seen:
                continue
            seen.add(sid)

        jsonl = transcript_for(cfg, cwd, sid) or newest_transcript(cfg, cwd)
        info  = (parse_claude_jsonl(jsonl) if jsonl
                 else {"model": "", "usage": None, "ts": None, "last_turn": ""})

        model = info["model"]
        used  = 0
        if info["usage"]:
            u = info["usage"]
            used = (u.get("input_tokens", 0)
                    + u.get("cache_read_input_tokens", 0)
                    + u.get("cache_creation_input_tokens", 0))
        window = ctx_window(model)
        if window:
            context_str = f"{used // 1000}k/{window // 1000}k"
            ratio       = used / window if used else None
            ctx_unknown = False
        else:
            # Window not in the table — show the raw count and flag it lavender
            # rather than inventing a denominator.
            context_str = f"{used // 1000}k"
            ratio       = None
            ctx_unknown = True

        status, waiting = claude_status(
            reg.get("status"), pane_target, info["last_turn"], bool(jsonl))

        # The per-client config dir (e.g. bambee) drives the SESSION color.
        source = "claude_bambee" if "bambee" in cfg.lower() else "claude_default"
        out.append({
            "type":          "claude",
            "source":        source,
            "tmux_session":  tmux_session,
            "project_name":  os.path.basename(cwd),
            "branch":        git_branch(cwd),
            "short_dir":     parent_basename(cwd),
            "status":        status,
            "model_display": pretty_model(model),
            "context_str":   context_str,
            "ratio":         ratio,
            "ctx_unknown":   ctx_unknown,
            "ts":            info["ts"] or reg.get("updatedAt"),
            "waiting":       waiting,
        })
    return out


def git_branch(cwd: str) -> str:
    try:
        r = subprocess.run(
            ["git", "-C", cwd, "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True, text=True, timeout=2,
        )
        return r.stdout.strip() if r.returncode == 0 else ""
    except Exception:
        return ""


# ── Codex sessions (via SQLite + tmux pane scan) ──────────────────────────────

def live_codex_panes(pane_info: dict, ppid_map: dict, procs: list) -> list:
    """Return [(codex_pid, tmux_session, pane_path), ...] for running Codex panes.

    Codex's NPM wrapper runs as `node /opt/homebrew/bin/codex`, which in turn
    execs the actual Rust binary (deep inside node_modules). The logs DB keys
    on the Rust binary's PID, and the JS wrapper is what's parented to the
    shell — so the binary is two levels below the pane_pid. Walk up the ppid
    chain from every codex binary process until we hit a known pane_pid.
    """
    results = []
    for pid, _ppid, cmd in procs:
        # The Rust codex binary lives under @openai/codex-<arch>/.../bin/codex.
        # That's the PID that shows up in ~/.codex/logs_2.sqlite process_uuid.
        # Exclude the `node /opt/homebrew/bin/codex` JS shim by ignoring node.
        if "@openai/codex-" not in cmd or not cmd.rstrip().endswith("/bin/codex"):
            continue
        owner = owning_pane(pid, ppid_map, pane_info)
        if owner:
            sess, path, _pane_id = owner
            results.append((pid, sess, path))
    return results


def fetch_codex(pane_info: dict, ppid_map: dict, procs: list) -> list:
    if not os.path.exists(CODEX_STATE):
        return []
    panes = live_codex_panes(pane_info, ppid_map, procs)
    if not panes:
        return []

    now_ms = datetime.now(timezone.utc).timestamp() * 1000
    out    = []
    seen   = set()

    try:
        db_s = sqlite3.connect(f"file:{CODEX_STATE}?mode=ro", uri=True)
        db_s.row_factory = sqlite3.Row
        db_l = sqlite3.connect(f"file:{CODEX_LOGS}?mode=ro", uri=True) \
               if os.path.exists(CODEX_LOGS) else None

        all_threads = db_s.execute(
            "SELECT id, cwd, model, updated_at_ms, tokens_used, has_user_event "
            "FROM threads WHERE archived=0 ORDER BY updated_at_ms DESC"
        ).fetchall()

        for codex_pid, tmux_session, pane_path in panes:
            thread_id = None

            # Primary: match via PID recorded in logs process_uuid
            if db_l:
                row = db_l.execute(
                    "SELECT thread_id FROM logs "
                    "WHERE process_uuid LIKE ? ORDER BY ts DESC LIMIT 1",
                    (f"pid:{codex_pid}:%",),
                ).fetchone()
                if row:
                    thread_id = row[0]

            # Fallback: cwd prefix match
            if not thread_id:
                for t in all_threads:
                    cwd = t["cwd"] or ""
                    if pane_path.startswith(cwd) or cwd.startswith(pane_path):
                        thread_id = t["id"]
                        break

            if not thread_id or thread_id in seen:
                continue
            seen.add(thread_id)

            t = db_s.execute(
                "SELECT cwd, model, git_branch, updated_at_ms, tokens_used, "
                "has_user_event FROM threads WHERE id=?", (thread_id,)
            ).fetchone()
            if not t:
                continue

            age_s = (now_ms - (t["updated_at_ms"] or 0)) / 1000
            if t["has_user_event"]:
                status = "Waiting"
            elif age_s < 60:
                status = "Running"
            else:
                status = "Idle"

            cwd = t["cwd"] or ""
            out.append({
                "type":          "codex",
                "source":        "codex",
                "tmux_session":  tmux_session,
                "project_name":  os.path.basename(cwd),
                "branch":        t["git_branch"] or "",
                "short_dir":     parent_basename(cwd),
                "status":        status,
                "model_display": pretty_model(t["model"] or ""),
                "context_str":   fmt_tokens(t["tokens_used"] or 0),
                "ratio":         None,
                "ts":            t["updated_at_ms"],
                "waiting":       bool(t["has_user_event"]),
            })

        db_s.close()
        if db_l:
            db_l.close()

    except sqlite3.Error:
        pass

    return out


# ── Merged load ───────────────────────────────────────────────────────────────

def load_sessions() -> tuple:
    pane_info, ppid_map, procs = scan_panes()
    claude = fetch_claude(pane_info, ppid_map, procs)
    codex  = fetch_codex(pane_info, ppid_map, procs)
    merged = claude + codex
    merged.sort(key=lambda s: s.get("tmux_session", "").lower())

    warnings = []
    if not merged:
        warnings.append("no sessions found")
    return merged, warnings


# ── Rendering ─────────────────────────────────────────────────────────────────

MENU_ITEMS = [
    ("j/k",   "move"),
    ("enter", "switch"),
    ("n",     "next-input"),
    ("r",     "refresh"),
    ("q",     "quit"),
]


def compute_widths(term_w: int) -> list:
    """Stretch configured widths proportionally to fill the terminal."""
    weights        = [COL_SESSION, COL_PROJECT, COL_DIR,
                      COL_STATUS, COL_MODEL, COL_CONTEXT, COL_LAST]
    fixed_overhead = 2 + (len(weights) - 1)   # "  " indicator + inter-cell gaps
    avail          = max(0, term_w - fixed_overhead)
    weight_sum     = sum(weights)
    if avail <= weight_sum:
        return list(weights)
    widths = [max(w, round(avail * w / weight_sum)) for w in weights]
    # Rebalance so the row exactly fills `avail` (rounding drift).
    drift = sum(widths) - avail
    while drift > 0:
        # Shrink the column furthest above its weight by 1.
        i = max(range(len(widths)), key=lambda i: widths[i] - weights[i])
        if widths[i] <= weights[i]:
            break
        widths[i] -= 1
        drift -= 1
    if drift < 0:
        widths[-1] += -drift
    return widths


def current_tmux_session() -> str:
    """Name of the tmux session the monitor itself is running in."""
    try:
        r = subprocess.run(
            ["tmux", "display-message", "-p", "#S"],
            capture_output=True, text=True, timeout=5,
        )
        return r.stdout.strip()
    except Exception:
        return ""


def status_color(status: str):
    return C_STATUS.get(status, C_NORMAL)


def _lerp_rgb(a, b, t):
    """Linear blend between two (r,g,b) tuples; t in [0,1]."""
    return tuple(round(a[i] + (b[i] - a[i]) * t) for i in range(3))


def context_color(ratio, unknown=False):
    if unknown:
        return C_CTX_UNKNOWN
    if ratio is None:          # no usage ratio to color (Codex rows, zero usage)
        return C_CTX_OK
    r = max(0.0, min(1.0, ratio))   # clamp; >100% pins to the red anchor
    if r <= 0.5:
        return _lerp_rgb(C_CTX_LOW, C_CTX_MID, r / 0.5)
    return _lerp_rgb(C_CTX_MID, C_CTX_HIGH, (r - 0.5) / 0.5)


def fit(s: str, width: int) -> str:
    """Plain truncate-or-pad to `width` visible chars."""
    s = str(s)
    if len(s) > width:
        return s[:width - 1] + "~"
    return s + " " * (width - len(s))


def cell(text: str, color, width: int) -> str:
    """A single-color fixed-width cell."""
    return fg(color) + fit(text, width)


def session_cell(name: str, color, related: bool, width: int) -> str:
    """Session name prefixed by a gold star (related) or a space (aligns the rest)."""
    marker = (fg(C_STAR) + STAR_GLYPH) if related else " "
    return marker + fg(color) + fit(name, width - 1)


def project_cell(project: str, branch, width: int) -> str:
    """Project name in bright; if branch is non-trivial, append ' <glyph> branch' in green."""
    if not branch_visible(branch):
        return cell(project, C_BRIGHT, width)

    # Layout: <project><space><glyph><space><branch>, sharing the cell width.
    suffix     = f" {BRANCH_GLYPH} {branch}"
    full_plain = (project or "") + suffix
    if len(full_plain) <= width:
        body = (
            fg(C_BRIGHT) + project +
            fg(C_BRANCH) + suffix +
            " " * (width - len(full_plain))
        )
        return body

    # Doesn't fit — give project priority, then squeeze the suffix.
    if len(project) >= width - 1:
        return fg(C_BRIGHT) + project[:width - 1] + "~"
    room = width - len(project)
    # room >= 2: at least space for "~"
    suffix_trunc = suffix[:room - 1] + "~"
    return fg(C_BRIGHT) + project + fg(C_BRANCH) + suffix_trunc


def render_menu(term_w: int) -> str:
    """Bottom status line: keys + descriptions, padded across the row."""
    text   = ""
    plain  = ""
    for k, desc in MENU_ITEMS:
        chunk_plain = f"  {k} {desc}"
        text  += fg(C_MENU_KEY) + f"  {k}" + fg(C_MENU_TEXT) + f" {desc}"
        plain += chunk_plain
    pad = max(0, term_w - len(plain))
    return bg(BG_MENU) + text + " " * pad + RESET


def render(sessions: list, selected: int, warnings: list,
           current_session: str = "", hover=None) -> None:
    try:
        size   = os.get_terminal_size()
        term_w = size.columns
        term_h = size.lines
    except OSError:
        term_w, term_h = 100, 24

    widths = compute_widths(term_w)
    col_s, col_p, col_d, col_st, col_m, col_c, col_l = widths

    buf = [HIDE_CUR, CLR_SCR]

    # Header — teal, bold, no leading indicator color
    headers = ["SESSION", "PROJECT", "DIR", "STATUS", "MODEL", "CONTEXT", "LAST ACTIVE"]
    header_cells = [cell(h, C_HEADER, w) for h, w in zip(headers, widths)]
    buf.append(BOLD + "  " + " ".join(header_cells) + RESET + CLR_EOL + "\r\n")

    # Rows used: 1 header + 1 menu + (1 if any warning). Body takes the rest.
    body_budget = max(1, term_h - 2 - (1 if warnings else 0))
    visible     = sessions[:body_budget]

    if visible:
        for i, s in enumerate(visible):
            is_sel   = (i == selected)
            is_hover = (i == hover)
            row_parts = []
            if is_sel and is_hover:
                row_parts.append(bg(BG_SELECTED_HOVER))
            elif is_sel:
                row_parts.append(bg(BG_SELECTED))
            elif is_hover:
                row_parts.append(bg(BG_HOVER))
            if is_sel:
                row_parts.append(fg(C_BRIGHT) + "▶ ")
            else:
                row_parts.append(fg(C_DIM) + "  ")
            sess_color = SRC_COLOR.get(s.get("source", ""), C_BRIGHT)
            related    = bool(current_session) and \
                         s["tmux_session"] == current_session
            cells = [
                session_cell(s["tmux_session"], sess_color, related,  col_s),
                project_cell(s["project_name"], s["branch"],           col_p),
                cell(s["short_dir"],        C_NORMAL,                  col_d),
                cell(s["status"],           status_color(s["status"]), col_st),
                cell(s["model_display"],    C_NORMAL,                  col_m),
                cell(s["context_str"],      context_color(s["ratio"], s.get("ctx_unknown")), col_c),
                cell(fmt_age(s["ts"]),      C_NORMAL,                  col_l),
            ]
            row_parts.append(" ".join(cells))
            row_parts.append(FG_DEF + CLR_EOL + RESET + "\r\n")
            buf.append("".join(row_parts))
    else:
        buf.append(fg(C_DIM) + "  (no sessions)" + RESET + CLR_EOL + "\r\n")

    # Warnings (one line each, above the menu)
    for w in warnings[:1]:
        buf.append("  " + fg(C_WARN) + w + RESET + CLR_EOL + "\r\n")

    # Menu pinned to the last row of the pane
    buf.append(f"\033[{term_h};1H")
    buf.append(render_menu(term_w))

    sys.stdout.write("".join(buf))
    sys.stdout.flush()


# ── Keyboard / mouse ──────────────────────────────────────────────────────────

def parse_mouse(seq: str):
    """Parse an SGR mouse body like '0;34;12M' → ('MOUSE', button, x, y, final).

    `final` is 'M' for press/motion, 'm' for release. Returns None on garbage.
    """
    try:
        b, x, y = (int(p) for p in seq[:-1].split(";"))
    except ValueError:
        return None
    return ("MOUSE", b, x, y, seq[-1])


def read_char(fd: int, timeout: float):
    rlist, _, _ = select.select([fd], [], [], timeout)
    if not rlist:
        return None
    return os.read(fd, 1).decode("utf-8", errors="replace")


def read_key(fd: int, timeout: float):
    ch = read_char(fd, timeout)
    if ch is None:
        return "TIMEOUT"
    if ch != "\x1b":
        return ch
    ch2 = read_char(fd, 0.05)
    if ch2 != "[":
        return "ESC"
    ch3 = read_char(fd, 0.05)
    if ch3 is None:
        return "ESC"
    if ch3 == "<":
        # SGR mouse: read the rest of the sequence up to its 'M'/'m' terminator.
        seq = ""
        while True:
            c = read_char(fd, 0.05)
            if c is None:
                return "IGNORE"
            seq += c
            if c in ("M", "m"):
                break
        return parse_mouse(seq) or "IGNORE"
    return "ESC[" + ch3


# ── Main ──────────────────────────────────────────────────────────────────────

def self_mtime():
    """mtime of this script (following the ~/bin symlink), or None if unreadable.

    A new version of `sessions` should take over each workon monitor pane without
    the user touching it. We can't reload Python in place, so on each refresh we
    compare this against the value captured at startup; a change means exit
    cleanly and let `sessions-loop` relaunch the fresh file."""
    try:
        return os.stat(SELF_PATH).st_mtime
    except OSError:
        return None


def main() -> None:
    if not os.environ.get("TMUX"):
        print("sessions: must be run inside tmux", file=sys.stderr)
        sys.exit(1)

    fd    = sys.stdin.fileno()
    saved = termios.tcgetattr(fd)

    def restore():
        try:
            termios.tcsetattr(fd, termios.TCSADRAIN, saved)
            sys.stdout.write(MOUSE_OFF + SHOW_CUR + "\r\n")
            sys.stdout.flush()
        except Exception:
            pass

    sessions, warnings = [], []
    selected    = 0
    hover       = None   # body-row index under the mouse, or None
    switch_to   = None   # set when user picks a session to switch to
    current     = current_tmux_session()
    started_mtime = self_mtime()   # baseline for self-restart on script change

    try:
        tty.setraw(fd)
        sys.stdout.write(MOUSE_ON)
        sys.stdout.flush()
        sessions, warnings = load_sessions()
        render(sessions, selected, warnings, current, hover)

        while True:
            key = read_key(fd, REFRESH_SECS)

            if key in ("TIMEOUT", "r"):
                # Script changed on disk → exit so sessions-loop relaunches the
                # new version. The finally below restores the terminal, so the
                # fresh instance re-arms raw/mouse mode cleanly.
                if self_mtime() not in (None, started_mtime):
                    break
                sessions, warnings = load_sessions()
                selected = min(selected, max(0, len(sessions) - 1))
                if hover is not None and hover >= len(sessions):
                    hover = None
                render(sessions, selected, warnings, current, hover)
                continue

            if key in ("q", "\x03", "ESC"):
                break

            # Mouse: hover brightens a row; a click selects it (or switches if it
            # is already the highlighted row). Row i renders on terminal line i+2
            # (line 1 is the header), so the body index is y-2.
            if isinstance(key, tuple) and key[0] == "MOUSE":
                _, b, _x, y, final = key
                if not sessions or final != "M":
                    continue
                idx   = y - 2
                valid = 0 <= idx < len(sessions)
                if b & 32:                          # any-motion → hover
                    new_hover = idx if valid else None
                    if new_hover != hover:
                        hover = new_hover
                        render(sessions, selected, warnings, current, hover)
                elif (b & 0b1100011) == 0 and valid:   # plain left-button press
                    hover = idx
                    if idx == selected:
                        switch_to = sessions[idx]["tmux_session"]
                        break
                    selected = idx
                    render(sessions, selected, warnings, current, hover)
                continue

            if not sessions:
                continue

            if key in ("j", "ESC[B"):       # down
                selected = (selected + 1) % len(sessions)
                render(sessions, selected, warnings, current, hover)

            elif key in ("k", "ESC[A"):     # up
                selected = (selected - 1) % len(sessions)
                render(sessions, selected, warnings, current, hover)

            elif key in ("\r", "\n", "l", "ESC[C"):   # enter / l / →
                switch_to = sessions[selected]["tmux_session"]
                break

            elif key == "n":                # next waiting for input
                waiting = [i for i, s in enumerate(sessions) if s["waiting"]]
                if waiting:
                    nxt = next((i for i in waiting if i > selected), waiting[0])
                    switch_to = sessions[nxt]["tmux_session"]
                    break

    except KeyboardInterrupt:
        pass
    finally:
        restore()

    if switch_to:
        subprocess.run(["tmux", "switch-client", "-t", f"={switch_to}"])


if __name__ == "__main__":
    main()
