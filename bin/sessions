#!/usr/bin/env python3
"""Unified session monitor: Claude Code (via JSONL transcripts) + Codex (via SQLite).

Both agents are discovered the same way: scan tmux panes, walk the process tree
to find the agent's real process (it runs under wrappers, so pane_current_command
is not "claude"/"codex"), then read that agent's own on-disk state for model,
tokens, branch, and status.
"""

import glob
import json
import os
import re
import select
import sqlite3
import subprocess
import sys
import termios
import tty
from datetime import datetime, timezone

# ── Column widths ─────────────────────────────────────────────────────────────

COL_SESSION = 20
COL_PROJECT = 28
COL_DIR     = 22
COL_STATUS  =  8
COL_MODEL   = 12
COL_CONTEXT = 12
COL_LAST    = 11

REFRESH_SECS       = 5.0

# Path to this script, resolved through the ~/bin symlink so we stat the real
# file in the dotfiles checkout. Used to self-restart when the script changes.
SELF_PATH = os.path.realpath(__file__)

CODEX_STATE        = os.path.expanduser("~/.codex/state_5.sqlite")
CODEX_LOGS         = os.path.expanduser("~/.codex/logs_2.sqlite")
CLAUDE_DEFAULT_CFG = os.path.expanduser("~/.claude")

# Context windows come from a dotfiles-managed table (refreshed in weekly
# maintenance from Anthropic's public models docs), symlinked into place by
# install.sh. bin/sessions only reads it — it never calls the API. When a model
# isn't in the table the CONTEXT column shows the raw token count (no window)
# in lavender to flag "usage unknown". See ctx_window() / _load_model_windows().
MODELS_TABLE = os.path.join(
    os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config"),
    "sessions", "models.json",
)

# ── ANSI ──────────────────────────────────────────────────────────────────────

RESET    = "\033[0m"
BOLD     = "\033[1m"
HIDE_CUR = "\033[?25l"
SHOW_CUR = "\033[?25h"
CLR_SCR  = "\033[2J\033[H"
CLR_EOL  = "\033[K"
FG_DEF   = "\033[39m"
BG_DEF   = "\033[49m"

# Mouse: 1003 = report any-motion + button events, 1006 = SGR extended coords
# (so columns/rows past 223 still parse). Enabled while the monitor runs.
MOUSE_ON  = "\033[?1003h\033[?1006h"
MOUSE_OFF = "\033[?1006l\033[?1003l"


def fg(rgb):
    r, g, b = rgb
    return f"\033[38;2;{r};{g};{b}m"


def bg(rgb):
    r, g, b = rgb
    return f"\033[48;2;{r};{g};{b}m"


