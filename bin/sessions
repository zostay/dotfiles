#!/usr/bin/env python3
"""Unified session monitor: Claude Code (via recon json) + Codex (via SQLite)."""

import json
import os
import select
import sqlite3
import subprocess
import sys
import termios
import tty
from datetime import datetime, timezone

# ── Column widths ─────────────────────────────────────────────────────────────

COL_SESSION = 20
COL_PROJECT = 28
COL_DIR     = 22
COL_STATUS  =  8
COL_MODEL   = 12
COL_CONTEXT = 12
COL_LAST    = 11

REFRESH_SECS = 5.0
CODEX_STATE  = os.path.expanduser("~/.codex/state_5.sqlite")
CODEX_LOGS   = os.path.expanduser("~/.codex/logs_2.sqlite")

# ── ANSI ──────────────────────────────────────────────────────────────────────

RESET    = "\033[0m"
BOLD     = "\033[1m"
HIDE_CUR = "\033[?25l"
SHOW_CUR = "\033[?25h"
CLR_SCR  = "\033[2J\033[H"
CLR_EOL  = "\033[K"
FG_DEF   = "\033[39m"
BG_DEF   = "\033[49m"


def fg(rgb):
    r, g, b = rgb
    return f"\033[38;2;{r};{g};{b}m"


def bg(rgb):
    r, g, b = rgb
    return f"\033[48;2;{r};{g};{b}m"


# ── Palette ───────────────────────────────────────────────────────────────────

C_HEADER    = ( 80, 200, 200)   # teal
C_BRIGHT    = (240, 240, 240)   # project name
C_NORMAL    = (190, 190, 190)   # lightgray default
C_DIM       = (130, 130, 130)   # idle, separators
C_BRANCH    = (120, 210, 140)   # branch + glyph
C_WARN      = (235, 200,  90)   # yellow

# Source palette: SESSION column color identifies which agent + config
# produced the session. Each pastel sits at roughly the brightness of
# C_NORMAL so they coexist visually without one dominating.
C_SRC_CLAUDE_DEFAULT = (120, 195, 250)   # saturated sky blue
C_SRC_CLAUDE_BAMBEE  = (200, 150, 250)   # saturated lavender
C_SRC_CODEX          = (120, 230, 165)   # saturated mint

SRC_COLOR = {
    "claude_default": C_SRC_CLAUDE_DEFAULT,
    "claude_bambee":  C_SRC_CLAUDE_BAMBEE,
    "codex":          C_SRC_CODEX,
}

BAMBEE_PREFIX = os.path.expanduser("~/projects/bambee") + "/"

# Status colors
C_STATUS = {
    "Idle":    (130, 130, 130),
    "New":     (110, 165, 245),
    "Running": (120, 210, 140),
    "Working": (120, 210, 140),
    "Busy":    (120, 210, 140),
    "Waiting": (235, 200,  90),
}

# Context-usage colors (ratio = used / window)
C_CTX_OK    = C_NORMAL
C_CTX_WARN  = (235, 200,  90)
C_CTX_OVER  = (235, 110, 110)

# Backgrounds — selected and menu bars use these. Picked to stay visibly
# distinct from every foreground in the palette so no text vanishes.
BG_SELECTED = ( 50,  58,  78)
BG_MENU     = ( 28,  30,  40)
C_MENU_KEY  = C_HEADER
C_MENU_TEXT = (190, 190, 190)

# ── Helpers ───────────────────────────────────────────────────────────────────

def trunc(s: str, width: int) -> str:
    s = str(s)
    if len(s) <= width:
        return s.ljust(width)
    return s[:width - 1] + "~"


BRANCH_GLYPH = ""  # Nerd Font powerline branch symbol


def branch_visible(branch) -> bool:
    return bool(branch) and branch.lower() not in ("main", "master")


def parent_basename(path: str) -> str:
    """/Users/sterling/projects/bambee/panfactum -> bambee/panfactum."""
    if not path:
        return ""
    parent = os.path.basename(os.path.dirname(path))
    base   = os.path.basename(path)
    return f"{parent}/{base}" if parent else base


def pretty_model(name: str) -> str:
    """claude-sonnet-4-6 -> Sonnet 4.6, gpt-5.5 -> GPT 5.5."""
    if not name:
        return ""
    n = name.strip()
    if n.startswith("claude-"):
        parts = n.split("-")
        # claude-{family}-{maj}-{min} → "Family maj.min"
        if len(parts) >= 4:
            family = parts[1].capitalize()
            return f"{family} {parts[2]}.{parts[3]}"
        return n
    if n.startswith("gpt-"):
        return "GPT " + n[4:]
    return n


def fmt_age(ts) -> str:
    """ISO-8601 string or millisecond int → relative time string."""
    if ts is None:
        return "-"
    now = datetime.now(timezone.utc)
    if isinstance(ts, str):
        try:
            dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        except ValueError:
            return "?"
    else:
        dt = datetime.fromtimestamp(ts / 1000, tz=timezone.utc)
    secs = max(0, int((now - dt).total_seconds()))
    if secs < 60:
        return f"{secs}s ago"
    if secs < 3600:
        return f"{secs // 60}m ago"
    if secs < 86400:
        return f"{secs // 3600}h ago"
    return f"{secs // 86400}d ago"


def fmt_tokens(n: int) -> str:
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M tok"
    if n >= 1_000:
        return f"{n // 1_000}k tok"
    return f"{n} tok"


def ts_seconds(s: dict) -> float:
    """Return sort key (Unix seconds) for a session record."""
    ts = s.get("ts")
    if ts is None:
        return 0.0
    if isinstance(ts, str):
        try:
            return datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
        except ValueError:
            return 0.0
    return ts / 1000.0


# ── Claude sessions (via recon json) ─────────────────────────────────────────

def fetch_claude() -> list:
    try:
        r = subprocess.run(
            ["recon", "json"], capture_output=True, text=True, timeout=5
        )
        data = json.loads(r.stdout)
    except Exception:
        return []
    out = []
    for s in data.get("sessions", []):
        status = s.get("status", "Idle")
        cwd    = s.get("cwd") or ""
        source = "claude_bambee" if cwd.startswith(BAMBEE_PREFIX) else "claude_default"
        out.append({
            "type":          "claude",
            "source":        source,
            "tmux_session":  s.get("tmux_session", ""),
            "project_name":  s.get("project_name", ""),
            "branch":        s.get("branch") or "",
            "short_dir":     parent_basename(s.get("cwd", "")),
            "status":        status,
            "model_display": pretty_model(s.get("model_display") or s.get("model", "")),
            "context_str":   (s.get("context_display") or "").replace(" ", ""),
            "ratio":         s.get("token_ratio"),
            "ts":            s.get("last_activity"),
            "waiting":       "wait" in status.lower(),
        })
    return out


# ── Codex sessions (via SQLite + tmux pane scan) ──────────────────────────────

def live_codex_panes() -> list:
    """Return [(codex_pid, tmux_session, pane_path), ...] for running Codex panes.

    Codex's NPM wrapper runs as `node /opt/homebrew/bin/codex`, which in turn
    execs the actual Rust binary (deep inside node_modules). The logs DB keys
    on the Rust binary's PID, and the JS wrapper is what's parented to the
    shell — so the binary is two levels below the pane_pid. Walk up the ppid
    chain from every codex binary process until we hit a known pane_pid.
    """
    try:
        r = subprocess.run(
            ["tmux", "list-panes", "-a", "-F",
             "#{pane_pid}|||#{session_name}|||#{pane_current_path}"],
            capture_output=True, text=True, timeout=5,
        )
    except Exception:
        return []
    pane_info = {}
    for line in r.stdout.splitlines():
        parts = line.split("|||", 2)
        if len(parts) != 3:
            continue
        try:
            pane_info[int(parts[0])] = (parts[1], parts[2])
        except ValueError:
            pass
    if not pane_info:
        return []

    # Snapshot the process table once.
    try:
        ps = subprocess.run(
            ["ps", "-axo", "pid=,ppid=,command="],
            capture_output=True, text=True, timeout=5,
        )
    except Exception:
        return []
    ppid_map     = {}
    codex_pids   = []
    for line in ps.stdout.splitlines():
        parts = line.strip().split(None, 2)
        if len(parts) < 3:
            continue
        try:
            pid  = int(parts[0])
            ppid = int(parts[1])
        except ValueError:
            continue
        cmd = parts[2]
        ppid_map[pid] = ppid
        # The Rust codex binary lives under @openai/codex-<arch>/.../bin/codex.
        # That's the PID that shows up in ~/.codex/logs_2.sqlite process_uuid.
        # Exclude the `node /opt/homebrew/bin/codex` JS shim by ignoring node.
        if "@openai/codex-" in cmd and cmd.rstrip().endswith("/bin/codex"):
            codex_pids.append(pid)

    results = []
    for cpid in codex_pids:
        cur = cpid
        for _ in range(20):                       # ascend at most 20 levels
            if cur in pane_info:
                sess, path = pane_info[cur]
                results.append((cpid, sess, path))
                break
            nxt = ppid_map.get(cur)
            if not nxt or nxt <= 1:
                break
            cur = nxt
    return results


def fetch_codex() -> list:
    if not os.path.exists(CODEX_STATE):
        return []
    panes = live_codex_panes()
    if not panes:
        return []

    now_ms = datetime.now(timezone.utc).timestamp() * 1000
    out    = []
    seen   = set()

    try:
        db_s = sqlite3.connect(f"file:{CODEX_STATE}?mode=ro", uri=True)
        db_s.row_factory = sqlite3.Row
        db_l = sqlite3.connect(f"file:{CODEX_LOGS}?mode=ro", uri=True) \
               if os.path.exists(CODEX_LOGS) else None

        all_threads = db_s.execute(
            "SELECT id, cwd, model, updated_at_ms, tokens_used, has_user_event "
            "FROM threads WHERE archived=0 ORDER BY updated_at_ms DESC"
        ).fetchall()

        for codex_pid, tmux_session, pane_path in panes:
            thread_id = None

            # Primary: match via PID recorded in logs process_uuid
            if db_l:
                row = db_l.execute(
                    "SELECT thread_id FROM logs "
                    "WHERE process_uuid LIKE ? ORDER BY ts DESC LIMIT 1",
                    (f"pid:{codex_pid}:%",),
                ).fetchone()
                if row:
                    thread_id = row[0]

            # Fallback: cwd prefix match
            if not thread_id:
                for t in all_threads:
                    cwd = t["cwd"] or ""
                    if pane_path.startswith(cwd) or cwd.startswith(pane_path):
                        thread_id = t["id"]
                        break

            if not thread_id or thread_id in seen:
                continue
            seen.add(thread_id)

            t = db_s.execute(
                "SELECT cwd, model, git_branch, updated_at_ms, tokens_used, "
                "has_user_event FROM threads WHERE id=?", (thread_id,)
            ).fetchone()
            if not t:
                continue

            age_s = (now_ms - (t["updated_at_ms"] or 0)) / 1000
            if t["has_user_event"]:
                status = "Waiting"
            elif age_s < 60:
                status = "Running"
            else:
                status = "Idle"

            cwd = t["cwd"] or ""
            out.append({
                "type":          "codex",
                "source":        "codex",
                "tmux_session":  tmux_session,
                "project_name":  os.path.basename(cwd),
                "branch":        t["git_branch"] or "",
                "short_dir":     parent_basename(cwd),
                "status":        status,
                "model_display": pretty_model(t["model"] or ""),
                "context_str":   fmt_tokens(t["tokens_used"] or 0),
                "ratio":         None,
                "ts":            t["updated_at_ms"],
                "waiting":       bool(t["has_user_event"]),
            })

        db_s.close()
        if db_l:
            db_l.close()

    except sqlite3.Error:
        pass

    return out


# ── Merged load ───────────────────────────────────────────────────────────────

def load_sessions() -> tuple:
    claude = fetch_claude()
    codex  = fetch_codex()
    merged = claude + codex
    merged.sort(key=lambda s: s.get("tmux_session", "").lower())

    warnings = []
    if not claude:
        warnings.append("recon unavailable — showing Codex only" if codex
                        else "no sessions found")
    return merged, warnings


# ── Rendering ─────────────────────────────────────────────────────────────────

MENU_ITEMS = [
    ("j/k",   "move"),
    ("enter", "switch"),
    ("n",     "next-input"),
    ("r",     "refresh"),
    ("q",     "quit"),
]


def compute_widths(term_w: int) -> list:
    """Stretch configured widths proportionally to fill the terminal."""
    weights        = [COL_SESSION, COL_PROJECT, COL_DIR,
                      COL_STATUS, COL_MODEL, COL_CONTEXT, COL_LAST]
    fixed_overhead = 2 + (len(weights) - 1)   # "  " indicator + inter-cell gaps
    avail          = max(0, term_w - fixed_overhead)
    weight_sum     = sum(weights)
    if avail <= weight_sum:
        return list(weights)
    widths = [max(w, round(avail * w / weight_sum)) for w in weights]
    # Rebalance so the row exactly fills `avail` (rounding drift).
    drift = sum(widths) - avail
    while drift > 0:
        # Shrink the column furthest above its weight by 1.
        i = max(range(len(widths)), key=lambda i: widths[i] - weights[i])
        if widths[i] <= weights[i]:
            break
        widths[i] -= 1
        drift -= 1
    if drift < 0:
        widths[-1] += -drift
    return widths


def status_color(status: str):
    return C_STATUS.get(status, C_NORMAL)


def context_color(ratio):
    if ratio is None:
        return C_CTX_OK
    if ratio > 1.0:
        return C_CTX_OVER
    if ratio > 0.5:
        return C_CTX_WARN
    return C_CTX_OK


def fit(s: str, width: int) -> str:
    """Plain truncate-or-pad to `width` visible chars."""
    s = str(s)
    if len(s) > width:
        return s[:width - 1] + "~"
    return s + " " * (width - len(s))


def cell(text: str, color, width: int) -> str:
    """A single-color fixed-width cell."""
    return fg(color) + fit(text, width)


def project_cell(project: str, branch, width: int) -> str:
    """Project name in bright; if branch is non-trivial, append ' <glyph> branch' in green."""
    if not branch_visible(branch):
        return cell(project, C_BRIGHT, width)

    # Layout: <project><space><glyph><space><branch>, sharing the cell width.
    suffix     = f" {BRANCH_GLYPH} {branch}"
    full_plain = (project or "") + suffix
    if len(full_plain) <= width:
        body = (
            fg(C_BRIGHT) + project +
            fg(C_BRANCH) + suffix +
            " " * (width - len(full_plain))
        )
        return body

    # Doesn't fit — give project priority, then squeeze the suffix.
    if len(project) >= width - 1:
        return fg(C_BRIGHT) + project[:width - 1] + "~"
    room = width - len(project)
    # room >= 2: at least space for "~"
    suffix_trunc = suffix[:room - 1] + "~"
    return fg(C_BRIGHT) + project + fg(C_BRANCH) + suffix_trunc


def render_menu(term_w: int) -> str:
    """Bottom status line: keys + descriptions, padded across the row."""
    text   = ""
    plain  = ""
    for k, desc in MENU_ITEMS:
        chunk_plain = f"  {k} {desc}"
        text  += fg(C_MENU_KEY) + f"  {k}" + fg(C_MENU_TEXT) + f" {desc}"
        plain += chunk_plain
    pad = max(0, term_w - len(plain))
    return bg(BG_MENU) + text + " " * pad + RESET


def render(sessions: list, selected: int, warnings: list) -> None:
    try:
        size   = os.get_terminal_size()
        term_w = size.columns
        term_h = size.lines
    except OSError:
        term_w, term_h = 100, 24

    widths = compute_widths(term_w)
    col_s, col_p, col_d, col_st, col_m, col_c, col_l = widths

    buf = [HIDE_CUR, CLR_SCR]

    # Header — teal, bold, no leading indicator color
    headers = ["SESSION", "PROJECT", "DIR", "STATUS", "MODEL", "CONTEXT", "LAST ACTIVE"]
    header_cells = [cell(h, C_HEADER, w) for h, w in zip(headers, widths)]
    buf.append(BOLD + "  " + " ".join(header_cells) + RESET + CLR_EOL + "\r\n")

    # Rows used: 1 header + 1 menu + (1 if any warning). Body takes the rest.
    body_budget = max(1, term_h - 2 - (1 if warnings else 0))
    visible     = sessions[:body_budget]

    if visible:
        for i, s in enumerate(visible):
            is_sel = (i == selected)
            row_parts = []
            if is_sel:
                row_parts.append(bg(BG_SELECTED))
                row_parts.append(fg(C_BRIGHT) + "▶ ")
            else:
                row_parts.append(fg(C_DIM) + "  ")
            sess_color = SRC_COLOR.get(s.get("source", ""), C_BRIGHT)
            cells = [
                cell(s["tmux_session"],     sess_color,                col_s),
                project_cell(s["project_name"], s["branch"],           col_p),
                cell(s["short_dir"],        C_NORMAL,                  col_d),
                cell(s["status"],           status_color(s["status"]), col_st),
                cell(s["model_display"],    C_NORMAL,                  col_m),
                cell(s["context_str"],      context_color(s["ratio"]), col_c),
                cell(fmt_age(s["ts"]),      C_NORMAL,                  col_l),
            ]
            row_parts.append(" ".join(cells))
            row_parts.append(FG_DEF + CLR_EOL + RESET + "\r\n")
            buf.append("".join(row_parts))
    else:
        buf.append(fg(C_DIM) + "  (no sessions)" + RESET + CLR_EOL + "\r\n")

    # Warnings (one line each, above the menu)
    for w in warnings[:1]:
        buf.append("  " + fg(C_WARN) + w + RESET + CLR_EOL + "\r\n")

    # Menu pinned to the last row of the pane
    buf.append(f"\033[{term_h};1H")
    buf.append(render_menu(term_w))

    sys.stdout.write("".join(buf))
    sys.stdout.flush()


# ── Keyboard ──────────────────────────────────────────────────────────────────

def read_key(fd: int, timeout: float) -> str:
    rlist, _, _ = select.select([fd], [], [], timeout)
    if not rlist:
        return "TIMEOUT"
    ch = os.read(fd, 1).decode("utf-8", errors="replace")
    if ch != "\x1b":
        return ch
    rlist2, _, _ = select.select([fd], [], [], 0.05)
    if not rlist2:
        return "ESC"
    ch2 = os.read(fd, 1).decode("utf-8", errors="replace")
    if ch2 != "[":
        return "ESC"
    rlist3, _, _ = select.select([fd], [], [], 0.05)
    if not rlist3:
        return "ESC"
    return "ESC[" + os.read(fd, 1).decode("utf-8", errors="replace")


# ── Main ──────────────────────────────────────────────────────────────────────

def main() -> None:
    if not os.environ.get("TMUX"):
        print("sessions: must be run inside tmux", file=sys.stderr)
        sys.exit(1)

    fd    = sys.stdin.fileno()
    saved = termios.tcgetattr(fd)

    def restore():
        try:
            termios.tcsetattr(fd, termios.TCSADRAIN, saved)
            sys.stdout.write(SHOW_CUR + "\r\n")
            sys.stdout.flush()
        except Exception:
            pass

    sessions, warnings = [], []
    selected    = 0
    switch_to   = None   # set when user picks a session to switch to

    try:
        tty.setraw(fd)
        sessions, warnings = load_sessions()
        render(sessions, selected, warnings)

        while True:
            key = read_key(fd, REFRESH_SECS)

            if key in ("TIMEOUT", "r"):
                sessions, warnings = load_sessions()
                selected = min(selected, max(0, len(sessions) - 1))
                render(sessions, selected, warnings)
                continue

            if key in ("q", "\x03", "ESC"):
                break

            if not sessions:
                continue

            if key in ("j", "ESC[B"):       # down
                selected = (selected + 1) % len(sessions)
                render(sessions, selected, warnings)

            elif key in ("k", "ESC[A"):     # up
                selected = (selected - 1) % len(sessions)
                render(sessions, selected, warnings)

            elif key in ("\r", "\n", "l", "ESC[C"):   # enter / l / →
                switch_to = sessions[selected]["tmux_session"]
                break

            elif key == "n":                # next waiting for input
                waiting = [i for i, s in enumerate(sessions) if s["waiting"]]
                if waiting:
                    nxt = next((i for i in waiting if i > selected), waiting[0])
                    switch_to = sessions[nxt]["tmux_session"]
                    break

    except KeyboardInterrupt:
        pass
    finally:
        restore()

    if switch_to:
        subprocess.run(["tmux", "switch-client", "-t", f"={switch_to}"])


if __name__ == "__main__":
    main()
