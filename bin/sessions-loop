#!/bin/zsh

# sessions-loop: keep `sessions` running in a pane. If it exits (clean or
# crash), pause briefly and relaunch. If sessions isn't installed, print a
# hint and back off so we don't spin.

emulate -L zsh

while true; do
    if ! command -v sessions >/dev/null 2>&1; then
        clear
        print -P "%F{244}sessions not on PATH — check dotfiles bin/%f"
        print -P "%F{244}retrying in 30s%f"
        sleep 30
        continue
    fi

    sessions

    sleep 0.5
done
