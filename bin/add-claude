#!/bin/zsh

# add-claude SESSION_NAME [SESSION_DIR]
#
# Build the standard 3-pane work layout in window 0:
#
#   +-----------+-----------+
#   | pane 0    | pane 1    |
#   | shell     | claude    |
#   +-----------+ (full     |
#   | pane 2    |  height)  |
#   | recon     |           |
#   +-----------+-----------+
#
# Pane 0 (shell) is expected to already exist; workon creates it via
# `new-session ... work-supervisor --default=zsh`.

SESSION_NAME="$1"
SESSION_DIR="$2"

if [[ -z "$SESSION_DIR" ]]; then
    SESSION_DIR="$PWD"
fi

# Right side: Claude under the supervisor so /exit drops to the menu.
tmux split-window -h -t "$SESSION_NAME:0.0" -c "$SESSION_DIR" \
    "work-supervisor --default=claude"

# Bottom-left: recon, ~20% of the left column, auto-restarted. This relies
# on workon having created the session at the client's real dimensions
# (via tmux new-session -x/-y) so the percentage resolves correctly.
tmux split-window -v -t "$SESSION_NAME:0.0" -l 20% \
    -c "$SESSION_DIR" "recon-loop"

tmux select-pane -t "$SESSION_NAME:0.0"
